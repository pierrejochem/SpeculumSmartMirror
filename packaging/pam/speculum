# PAM stack for the Speculum kiosk systemd unit (PAMName=speculum).
#
# Why a dedicated stack instead of PAMName=login: the distro's /etc/pam.d/login
# pulls in modules a headless kiosk doesn't need (pam_lastlog, pam_motd, mail
# checks…), and on newer distros pam_lastlog.so was removed entirely, so the
# system logs "PAM unable to dlopen(pam_lastlog.so)" / "adding faulty module".
#
# All we actually need is a session that pam_systemd registers with logind, so
# it creates /run/user/<uid> and exports XDG_RUNTIME_DIR — cage requires it.

auth        required    pam_permit.so
account     required    pam_permit.so
password    required    pam_permit.so

# Set the audit login uid, then hand the session to logind (creates the runtime
# dir + XDG_RUNTIME_DIR). pam_keyinit gives the session its own keyring.
session     required    pam_loginuid.so
session     optional    pam_keyinit.so force revoke
session     required    pam_systemd.so