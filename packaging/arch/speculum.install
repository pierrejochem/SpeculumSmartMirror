# Arch install scriptlet. The in-app updater stages packages under the mirror
# user's own ~/.speculum/update at runtime, so there's no root-owned staging dir
# to provision — just refresh systemd for the new updater unit.
post_install() { systemctl daemon-reload >/dev/null 2>&1 || true; }
post_upgrade() { systemctl daemon-reload >/dev/null 2>&1 || true; }
