// Authorize starting ONLY the Speculum updater oneshot unit, and only from an
// active local session. This is the entire privilege the in-app updater gains.
// The helper it starts re-verifies the signed package as root before installing,
// so this grants no ability to install arbitrary code — only genuine, signed
// Speculum releases. Scoping to local+active (rather than a hardcoded username)
// works whatever account the operator runs the mirror under.
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        action.lookup("unit") == "speculum-update.service" &&
        action.lookup("verb") == "start" &&
        subject.local && subject.active) {
        return polkit.Result.YES;
    }
});
